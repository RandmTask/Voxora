{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "Voxora",
  "options": {
    "deploymentTarget": {
      "iOS": "26.0",
      "watchOS": "26.0"
    },
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "schemes": {
    "Voxora": {
      "build": {
        "targets": {
          "Voxora": [
            "all"
          ]
        }
      },
      "run": {
        "config": "Debug"
      },
      "test": {
        "config": "Debug"
      },
      "profile": {
        "config": "Release"
      },
      "analyze": {
        "config": "Debug"
      },
      "archive": {
        "config": "Release"
      }
    },
    "Voxora Watch": {
      "build": {
        "targets": {
          "Voxora Watch": [
            "all"
          ]
        }
      },
      "run": {
        "config": "Debug"
      },
      "profile": {
        "config": "Release"
      },
      "analyze": {
        "config": "Debug"
      },
      "archive": {
        "config": "Release"
      }
    },
    "Voxora Widget Extension": {
      "build": {
        "targets": {
          "Voxora Widget Extension": [
            "all"
          ]
        }
      },
      "run": {
        "config": "Debug"
      },
      "profile": {
        "config": "Release"
      },
      "analyze": {
        "config": "Debug"
      },
      "archive": {
        "config": "Release"
      }
    }
  },
  "targets": {
    "Voxora": {
      "dependencies": [
        {
          "embed": true,
          "target": "Voxora Watch"
        }
      ],
      "info": {
        "path": "App\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Voxora",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "LSApplicationQueriesSchemes": [
            "mailto"
          ],
          "NSSupportsLiveActivities": false,
          "NSSpeechRecognitionUsageDescription": "Voxora transcribes transferred recordings on iPhone so you can turn them into summaries, checklists, and follow-up outputs.",
          "UILaunchScreen": {},
          "UIBackgroundModes": [
            "remote-notification"
          ],
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait",
            "UIInterfaceOrientationPortraitUpsideDown",
            "UIInterfaceOrientationLandscapeLeft",
            "UIInterfaceOrientationLandscapeRight"
          ],
          "NSMicrophoneUsageDescription": "Voxora records your voice notes on Apple Watch and iPhone so they can be transcribed and transformed into structured text.",
          "CFBundleURLTypes": [
            {
              "CFBundleURLName": "Voxora",
              "CFBundleURLSchemes": [
                "voxora"
              ]
            }
          ]
        }
      },
      "entitlements": {
        "path": "App/App.entitlements",
        "properties": {
          "com.apple.developer.icloud-container-identifiers": [
            "iCloud.com.swiftstudio.Voxora"
          ],
          "com.apple.developer.icloud-services": [
            "CloudKit"
          ],
          "com.apple.developer.ubiquity-container-identifiers": [
            "iCloud.com.swiftstudio.Voxora"
          ],
          "com.apple.security.application-groups": [
            "group.com.swiftstudio.Voxora"
          ]
        }
      },
      "platform": "iOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "com.swiftstudio.Voxora",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0",
        "TARGETED_DEVICE_FAMILY": "1"
      },
      "sources": [
        {
          "path": "App"
        },
        {
          "path": "Shared"
        }
      ],
      "type": "application"
    },
    "Voxora Watch": {
      "dependencies": [
        {
          "embed": true,
          "target": "Voxora Widget Extension"
        }
      ],
      "info": {
        "path": "Watch\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Voxora",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "NSMicrophoneUsageDescription": "Voxora records chunked audio on Apple Watch so you can pause, resume, and finish a note before it syncs to iPhone.",
          "WKApplication": true,
          "WKCompanionAppBundleIdentifier": "com.swiftstudio.Voxora",
          "CFBundleURLTypes": [
            {
              "CFBundleURLName": "Voxora",
              "CFBundleURLSchemes": [
                "voxora"
              ]
            }
          ]
        }
      },
      "entitlements": {
        "path": "Watch/Watch.entitlements",
        "properties": {
          "com.apple.developer.icloud-container-identifiers": [
            "iCloud.com.swiftstudio.Voxora"
          ],
          "com.apple.developer.icloud-services": [
            "CloudKit"
          ],
          "com.apple.developer.ubiquity-container-identifiers": [
            "iCloud.com.swiftstudio.Voxora"
          ],
          "com.apple.security.application-groups": [
            "group.com.swiftstudio.Voxora"
          ]
        }
      },
      "platform": "watchOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "com.swiftstudio.Voxora.watchkitapp",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0"
      },
      "sources": [
        {
          "path": "Watch"
        },
        {
          "path": "App\/Assets.xcassets"
        },
        {
          "path": "Shared"
        }
      ],
      "type": "application"
    },
    "Voxora Widget Extension": {
      "info": {
        "path": "Widget Extension\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Voxora Widget Extension",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "NSExtension": {
            "NSExtensionPointIdentifier": "com.apple.widgetkit-extension"
          }
        }
      },
      "entitlements": {
        "path": "Widget Extension/Widget Extension.entitlements",
        "properties": {
          "com.apple.security.application-groups": [
            "group.com.swiftstudio.Voxora"
          ]
        }
      },
      "platform": "watchOS",
      "settings": {
        "APPLICATION_EXTENSION_API_ONLY": "YES",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "com.swiftstudio.Voxora.watchkitapp.widget-extension",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SKIP_INSTALL": "YES",
        "SWIFT_VERSION": "5.0"
      },
      "sources": [
        {
          "path": "Widget Extension"
        },
        {
          "path": "Shared"
        }
      ],
      "type": "app-extension"
    }
  }
}
