{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "VoiceSynapse",
  "options": {
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "targets": {
    "VoiceSynapse": {
      "dependencies": [
        {
          "embed": true,
          "target": "VoiceSynapse Watch"
        }
      ],
      "deploymentTarget": "26.0",
      "info": {
        "path": "App\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "VoiceSynapse",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "UILaunchScreen": {},
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait",
            "UIInterfaceOrientationPortraitUpsideDown",
            "UIInterfaceOrientationLandscapeLeft",
            "UIInterfaceOrientationLandscapeRight"
          ]
        }
      },
      "platform": "iOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.bfc9a3b4-4284-492c-86c4-550c634ba81e",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0",
        "TARGETED_DEVICE_FAMILY": "1"
      },
      "sources": [
        {
          "path": "App"
        }
      ],
      "type": "application"
    },
    "VoiceSynapse Watch": {
      "dependencies": [
        {
          "embed": true,
          "target": "VoiceSynapse Widget Extension"
        }
      ],
      "deploymentTarget": "26.0",
      "info": {
        "path": "Watch\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "VoiceSynapse",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "WKApplication": true,
          "WKCompanionAppBundleIdentifier": "app.bitrig.new.bfc9a3b4-4284-492c-86c4-550c634ba81e"
        }
      },
      "platform": "watchOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.bfc9a3b4-4284-492c-86c4-550c634ba81e.watchkitapp",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0"
      },
      "sources": [
        {
          "path": "Watch"
        },
        {
          "path": "App\/Assets.xcassets"
        }
      ],
      "type": "application"
    },
    "VoiceSynapse Widget Extension": {
      "deploymentTarget": "26.0",
      "info": {
        "path": "Widget Extension\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "VoiceSynapse Widget Extension",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "NSExtension": {
            "NSExtensionPointIdentifier": "com.apple.widgetkit-extension"
          }
        }
      },
      "platform": "watchOS",
      "settings": {
        "APPLICATION_EXTENSION_API_ONLY": "YES",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.bfc9a3b4-4284-492c-86c4-550c634ba81e.watchkitapp.widget-extension",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SKIP_INSTALL": "YES",
        "SWIFT_VERSION": "5.0"
      },
      "sources": [
        {
          "path": "Widget Extension"
        }
      ],
      "type": "app-extension"
    }
  }
}
